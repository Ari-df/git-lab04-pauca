<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        android:textSize="24sp"/>

    <!-- COMPONENTE 1: TextView -->
    <TextView
        android:id="@+id/textViewComponente1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Componente 1: Mi TextView"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>
    <!-- COMPONENTE 2: Button -->
    <Button
        android:id="@+id/buttonComponente2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Componente 2: Mi Botón"
        android:layout_marginTop="20dp"/>
    <!-- COMPONENTE 3: EditText -->
    <EditText
        android:id="@+id/editTextComponente3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="📝 Tercer componente mejorado - Escribe tu película favorita"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:textSize="16sp"
        android:layout_marginTop="20dp"/>

</LinearLayout>